{
  "expo": {
    "name": "ObraCalc MX",
    "slug": "obracalc-mx",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "obracalcmx",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.obracalc.app"
    },
    "android": {
      "package": "mx.obracalc.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "ObraCalc MX",
      "shortName": "ObraCalc",
      "themeColor": "#1f6feb",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
